---
// p-adic number line: nested discs showing Z_5 as a fractal.
// Click to zoom in, revealing deeper levels of the expansion.
---

<div class="padic-discs">
  <canvas id="padic-canvas" width="600" height="600"></canvas>
  <div class="padic-controls">
    <button id="padic-back" type="button" disabled>Back</button>
    <span class="padic-breadcrumb" id="padic-breadcrumb">
      Z<sub>5</sub>
    </span>
  </div>
  <p class="padic-info" id="padic-info">
    Click a disc to zoom in. Each disc contains 5 sub-discs, one level deeper in
    the p-adic expansion.
  </p>
</div>

<script>
  const P = 5;
  // Only build/render 3 levels from current view; zoom reveals more
  const VISIBLE_DEPTH = 3;

  type Disc = {
    residue: number;
    modulus: number;
    depth: number;
    localDepth: number;
    cx: number;
    cy: number;
    r: number;
    children?: Disc[];
  };

  let history: { residue: number; modulus: number; depth: number }[] = [];
  let currentRoot: Disc | null = null;
  let rootResidue = 0;
  let rootModulus = 1;
  let rootDepth = 0;

  function getColor(name: string): string {
    return getComputedStyle(document.documentElement)
      .getPropertyValue(name)
      .trim();
  }

  // Layout: 1 disc in center, 4 around it in a ring.
  // This gives much larger children than packing 5 in a ring.
  function layoutChildren(
    cx: number,
    cy: number,
    parentR: number,
  ): { cx: number; cy: number; r: number }[] {
    // Center child gets ~38% of parent radius
    // Ring children get ~38% too, placed at ~58% of parent radius
    const childR = parentR * 0.38;
    const ringR = parentR * 0.58;
    const result: { cx: number; cy: number; r: number }[] = [];

    // Center child
    result.push({ cx, cy, r: childR });

    // 4 children in a ring
    for (let i = 0; i < 4; i++) {
      const angle = (i / 4) * 2 * Math.PI - Math.PI / 4;
      result.push({
        cx: cx + Math.cos(angle) * ringR,
        cy: cy + Math.sin(angle) * ringR,
        r: childR,
      });
    }

    return result;
  }

  function buildDisc(
    residue: number,
    modulus: number,
    depth: number,
    localDepth: number,
    cx: number,
    cy: number,
    r: number,
  ): Disc {
    const disc: Disc = {
      residue,
      modulus,
      depth,
      localDepth,
      cx,
      cy,
      r,
    };

    if (localDepth < VISIBLE_DEPTH && r > 3) {
      disc.children = [];
      const positions = layoutChildren(cx, cy, r);
      for (let i = 0; i < P; i++) {
        const pos = positions[i];
        disc.children.push(
          buildDisc(
            residue + i * modulus,
            modulus * P,
            depth + 1,
            localDepth + 1,
            pos.cx,
            pos.cy,
            pos.r,
          ),
        );
      }
    }

    return disc;
  }

  function hexToRgb(hex: string): [number, number, number] {
    hex = hex.replace("#", "");
    if (hex.length === 3) {
      hex = hex[0] + hex[0] + hex[1] + hex[1] + hex[2] + hex[2];
    }
    return [
      parseInt(hex.substring(0, 2), 16),
      parseInt(hex.substring(2, 4), 16),
      parseInt(hex.substring(4, 6), 16),
    ];
  }

  function render() {
    const canvas = document.getElementById("padic-canvas") as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.scale(dpr, dpr);
    const w = rect.width;
    const h = rect.height;

    const bg = getColor("--color-bg");
    const text = getColor("--color-text");
    const muted = getColor("--color-text-muted");
    const accent = getColor("--color-accent");
    const accentSec = getColor("--color-accent-secondary");
    const border = getColor("--color-border");

    const accentRgb = hexToRgb(accent);
    const accentSecRgb = hexToRgb(accentSec);
    const borderRgb = hexToRgb(border);

    ctx.fillStyle = bg;
    ctx.fillRect(0, 0, w, h);

    const r = Math.min(w, h) / 2 - 10;
    currentRoot = buildDisc(
      rootResidue,
      rootModulus,
      rootDepth,
      0,
      w / 2,
      h / 2,
      r,
    );

    // Color by local depth: deeper = more distinct
    const fillColors = [
      "rgba(" + accentRgb.join(",") + ",0.12)",
      "rgba(" + accentSecRgb.join(",") + ",0.2)",
      "rgba(" + borderRgb.join(",") + ",0.25)",
      "rgba(" + accentRgb.join(",") + ",0.3)",
    ];
    const strokeColors = [
      "rgba(" + accentRgb.join(",") + ",0.5)",
      "rgba(" + accentSecRgb.join(",") + ",0.7)",
      "rgba(" + borderRgb.join(",") + ",0.8)",
      "rgba(" + accentRgb.join(",") + ",0.9)",
    ];

    function drawDisc(disc: Disc) {
      ctx!.beginPath();
      ctx!.arc(disc.cx, disc.cy, disc.r, 0, Math.PI * 2);
      ctx!.fillStyle = fillColors[disc.localDepth % fillColors.length];
      ctx!.fill();
      ctx!.strokeStyle = strokeColors[disc.localDepth % strokeColors.length];
      ctx!.lineWidth = disc.localDepth === 0 ? 2 : 1;
      ctx!.stroke();

      if (disc.children) {
        disc.children.forEach(drawDisc);
      } else if (disc.r > 8) {
        // Label leaf discs
        const res = disc.residue % disc.modulus;
        const fontSize = Math.max(7, Math.min(14, disc.r / 2.5));
        ctx!.font = "600 " + fontSize + "px SourceCodePro, monospace";
        ctx!.fillStyle = muted;
        ctx!.textAlign = "center";
        ctx!.textBaseline = "middle";
        ctx!.fillText(String(res), disc.cx, disc.cy);
      }
    }

    drawDisc(currentRoot);

    // Label the root
    if (rootDepth === 0) {
      ctx.font = "700 18px SourceCodePro, monospace";
      ctx.fillStyle = accent;
      ctx.textAlign = "center";
      ctx.textBaseline = "middle";
    }
  }

  function handleCanvasClick(e: MouseEvent) {
    const canvas = document.getElementById("padic-canvas") as HTMLCanvasElement;
    if (!canvas || !currentRoot) return;

    const rect = canvas.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;

    function findClickedChild(disc: Disc): Disc | null {
      if (disc.children) {
        for (const child of disc.children) {
          const dx = x - child.cx;
          const dy = y - child.cy;
          if (dx * dx + dy * dy <= child.r * child.r) {
            // Prefer deeper match
            const deeper = findClickedChild(child);
            return deeper || child;
          }
        }
      }
      return null;
    }

    const clicked = findClickedChild(currentRoot);
    if (clicked && clicked.localDepth > 0) {
      history.push({
        residue: rootResidue,
        modulus: rootModulus,
        depth: rootDepth,
      });
      rootResidue = clicked.residue;
      rootModulus = clicked.modulus;
      rootDepth = clicked.depth;
      updateUI();
      render();
    }
  }

  function goBack() {
    if (history.length > 0) {
      const prev = history.pop()!;
      rootResidue = prev.residue;
      rootModulus = prev.modulus;
      rootDepth = prev.depth;
      updateUI();
      render();
    }
  }

  function updateUI() {
    const el = document.getElementById("padic-breadcrumb");
    const btn = document.getElementById("padic-back") as HTMLButtonElement;
    if (!el || !btn) return;

    btn.disabled = history.length === 0;

    if (rootDepth === 0) {
      el.innerHTML = "Z<sub>5</sub>";
    } else {
      el.innerHTML =
        "Z<sub>5</sub> > <strong>" +
        rootResidue +
        "</strong> mod " +
        rootModulus;
    }
  }

  document
    .getElementById("padic-canvas")
    ?.addEventListener("click", handleCanvasClick);
  document.getElementById("padic-back")?.addEventListener("click", goBack);

  new MutationObserver(render).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"],
  });

  window.addEventListener("resize", render);

  render();
</script>

<style is:global>
  .padic-discs {
    margin: 2rem 0;
  }

  .padic-discs canvas {
    width: 100%;
    max-width: 520px;
    height: auto;
    aspect-ratio: 1;
    display: block;
    margin: 0 auto;
    cursor: pointer;
  }

  .padic-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 0.75rem;
  }

  .padic-controls button {
    background-color: var(--color-bg-secondary);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.4rem 1rem;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .padic-controls button:hover:not(:disabled) {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .padic-controls button:disabled {
    opacity: 0.4;
    cursor: default;
  }

  .padic-breadcrumb {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .padic-breadcrumb strong {
    color: var(--color-accent);
  }

  .padic-info {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }
</style>
