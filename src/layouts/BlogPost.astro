---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  authorUrl?: string;
  tags?: string[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author = "BaDaaS",
  authorUrl,
  tags = [],
} = Astro.props;

const formatDate = (date: Date) => {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description: description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  author: {
    "@type": "Person",
    name: author,
    ...(authorUrl && { url: authorUrl }),
  },
  ...(tags.length > 0 && { keywords: tags }),
  publisher: {
    "@type": "Organization",
    name: "BaDaaS",
    url: "https://badaas.be",
    logo: {
      "@type": "ImageObject",
      url: "https://badaas.be/og-image.png",
    },
  },
});
---

<BaseLayout
  title={`${title} | BaDaaS Blog`}
  description={description}
  ogType="article"
  articleDate={pubDate.toISOString()}
  articleAuthor="https://badaas.be"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>
  <div class="blog-layout">
    <aside class="blog-toc" id="blog-toc" aria-label="Table of contents">
      <nav>
        <p class="blog-toc-title">Contents</p>
        <ul id="blog-toc-list"></ul>
      </nav>
    </aside>
    <article class="prose max-w-content mx-auto px-5 pt-24 pb-16">
      <h1 class="mb-2.5 text-4xl md:text-[2.5rem]">{title}</h1>
      <div class="text-text-muted mb-10 text-sm">
        <time datetime={pubDate.toISOString()}>
          {formatDate(pubDate)}
          {updatedDate && <span> (Updated: {formatDate(updatedDate)})</span>}
        </time>
        <span class="mx-2">|</span>
        {
          authorUrl ? (
            <a href={authorUrl} target="_blank" rel="noopener noreferrer">
              {author}
            </a>
          ) : (
            <span>{author}</span>
          )
        }
      </div>
      {
        tags.length > 0 && (
          <div class="mb-10 flex flex-wrap gap-2">
            {tags.map(tag => (
              <a href={`/blog/tags/${tag}`} class="tag-badge-sm">
                {tag}
              </a>
            ))}
          </div>
        )
      }
      <slot />
    </article>
  </div>

  <script>
    function buildToc() {
      const article = document.querySelector(".prose");
      const list = document.getElementById("blog-toc-list");
      if (!article || !list) return;

      const headings = article.querySelectorAll("h2, h3");
      if (headings.length === 0) {
        // Hide ToC if no headings
        const toc = document.getElementById("blog-toc");
        if (toc) toc.style.display = "none";
        return;
      }

      headings.forEach(function (h) {
        if (!h.id) {
          h.id = h
            .textContent!.toLowerCase()
            .replace(/[^a-z0-9]+/g, "-")
            .replace(/^-|-$/g, "");
        }
        const li = document.createElement("li");
        const a = document.createElement("a");
        a.href = "#" + h.id;
        a.textContent = h.textContent;
        if (h.tagName === "H3") {
          li.classList.add("toc-h3");
        }
        li.appendChild(a);
        list.appendChild(li);
      });

      // Highlight current section on scroll
      const links = list.querySelectorAll("a");
      const observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              links.forEach(function (l) {
                l.classList.remove("toc-active");
              });
              const active = list.querySelector(
                'a[href="#' + entry.target.id + '"]',
              );
              if (active) active.classList.add("toc-active");
            }
          });
        },
        { rootMargin: "-80px 0px -60% 0px", threshold: 0 },
      );

      headings.forEach(function (h) {
        observer.observe(h);
      });
    }

    buildToc();
  </script>
</BaseLayout>
