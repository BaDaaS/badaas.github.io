---
import "../styles/global.css";
import IconTwitter from "../components/icons/IconTwitter.astro";
import IconLinkedIn from "../components/icons/IconLinkedIn.astro";
import IconGitHub from "../components/icons/IconGitHub.astro";
import ThemeSelector from "../components/ThemeSelector.astro";
import Logo from "../components/Logo.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "From abstract mathematics to concrete applications. Formal verification, applied cryptography, and Internet security.",
} = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalURL = new URL(Astro.url.pathname, "https://badaas.be");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="BaDaaS" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#1a1f2e" />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="icon" href="/res/badaas-icon-dark-bg.svg" type="image/svg+xml" />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://badaas.be/og-image.png" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://badaas.be/og-image.png" />

    <!-- Organization JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "BaDaaS",
        "url": "https://badaas.be",
        "logo": "https://badaas.be/og-image.png",
        "description": "From abstract mathematics to concrete applications. Formal verification, applied cryptography, and Internet security.",
        "address": {
          "@type": "PostalAddress",
          "addressCountry": "BE"
        },
        "sameAs": [
          "https://twitter.com/be_badaas",
          "https://linkedin.com/company/bebadaas",
          "https://github.com/BaDaaS"
        ]
      }
    </script>

    <slot name="head" />
  </head>
  <body>
    <nav
      class="bg-bg/80 fixed inset-x-0 top-0 z-[100] border-b-2 border-dashed backdrop-blur-md"
      style="border-color: var(--color-border)"
    >
      <div class="flex items-center justify-between px-5 py-4 md:px-10 md:py-5">
        <a href="/" class="font-display text-2xl font-bold"><Logo /></a>

        <!-- Desktop nav -->
        <div class="hidden items-center gap-8 md:flex">
          <a
            href="/#services"
            class="text-text-muted hover:text-accent text-sm transition-colors"
            class:list={{ active: currentPath === "/" }}>What we do</a
          >
          <a
            href="/#portfolio"
            class="text-text-muted hover:text-accent text-sm transition-colors"
            >Trusted By</a
          >
          <a
            href="/#research"
            class="text-text-muted hover:text-accent text-sm transition-colors"
            >Research</a
          >
          <a
            href="/#projects"
            class="text-text-muted hover:text-accent text-sm transition-colors"
            >Open Source</a
          >
          <a
            href="/blog"
            class="text-text-muted hover:text-accent text-sm transition-colors"
            class:list={{ active: currentPath.startsWith("/blog") }}>Blog</a
          >
          <ThemeSelector />
          <a
            href="https://calendly.com/be-danny-willems/30min"
            class="btn-primary !px-5 !py-2 !text-sm">Book a call</a
          >
        </div>

        <!-- Mobile controls -->
        <div class="flex items-center gap-3 md:hidden">
          <ThemeSelector />
          <button
            id="menu-toggle"
            class="text-text-muted hover:text-accent p-1 transition-colors"
            aria-label="Toggle menu"
          >
            <svg
              id="menu-icon-open"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
            <svg
              id="menu-icon-close"
              class="hidden"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div
        id="mobile-menu"
        class="bg-bg/95 hidden border-t border-dashed backdrop-blur-md md:hidden"
        style="border-color: var(--color-border)"
      >
        <div class="flex flex-col gap-1 px-5 py-4">
          <a
            href="/#services"
            class="text-text-muted hover:text-accent hover:bg-accent/5 py-3 text-sm transition-colors"
            >What we do</a
          >
          <a
            href="/#portfolio"
            class="text-text-muted hover:text-accent hover:bg-accent/5 py-3 text-sm transition-colors"
            >Trusted By</a
          >
          <a
            href="/#research"
            class="text-text-muted hover:text-accent hover:bg-accent/5 py-3 text-sm transition-colors"
            >Research</a
          >
          <a
            href="/#projects"
            class="text-text-muted hover:text-accent hover:bg-accent/5 py-3 text-sm transition-colors"
            >Open Source</a
          >
          <a
            href="/blog"
            class="text-text-muted hover:text-accent hover:bg-accent/5 py-3 text-sm transition-colors"
            >Blog</a
          >
          <div class="pt-2">
            <a
              href="https://calendly.com/be-danny-willems/30min"
              class="btn-primary block !py-3 text-center !text-sm"
              >Book a call</a
            >
          </div>
        </div>
      </div>
    </nav>

    <script>
      const toggle = document.getElementById("menu-toggle");
      const menu = document.getElementById("mobile-menu");
      const iconOpen = document.getElementById("menu-icon-open");
      const iconClose = document.getElementById("menu-icon-close");

      toggle?.addEventListener("click", () => {
        const isOpen = !menu?.classList.contains("hidden");
        menu?.classList.toggle("hidden");
        iconOpen?.classList.toggle("hidden");
        iconClose?.classList.toggle("hidden");
      });

      // Close menu when a link is clicked
      menu?.querySelectorAll("a").forEach(link => {
        link.addEventListener("click", () => {
          menu?.classList.add("hidden");
          iconOpen?.classList.remove("hidden");
          iconClose?.classList.add("hidden");
        });
      });
    </script>

    <slot />

    <footer
      class="bg-bg-secondary border-t-2 border-dashed px-5 pt-16 pb-8"
      style="border-color: var(--color-border)"
    >
      <div
        class="max-w-container mx-auto grid grid-cols-1 gap-10 md:grid-cols-[1fr_2fr] md:gap-16"
      >
        <div class="flex flex-col gap-4">
          <div class="accent-bar mb-2"></div>
          <a href="/" class="font-display text-2xl font-bold"><Logo /></a>
          <p class="text-text-muted max-w-[280px] text-sm">
            We use abstract mathematics to build concrete applications. Making
            the Internet better and safer.
          </p>
          <div class="flex gap-4">
            <a
              href="https://twitter.com/be_badaas"
              aria-label="Twitter"
              class="text-icon hover:text-icon-hover transition-colors"
            >
              <IconTwitter />
            </a>
            <a
              href="https://linkedin.com/company/bebadaas"
              aria-label="LinkedIn"
              class="text-icon hover:text-icon-hover transition-colors"
            >
              <IconLinkedIn />
            </a>
            <a
              href="https://github.com/BaDaaS"
              aria-label="GitHub"
              class="text-icon hover:text-icon-hover transition-colors"
            >
              <IconGitHub />
            </a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-8 sm:grid-cols-4">
          <div class="flex flex-col gap-2.5">
            <h4 class="font-display text-accent mb-1 text-base">What we do</h4>
            <a
              href="/#services"
              class="text-text-muted hover:text-accent text-sm transition-colors"
              >Research</a
            >
            <a
              href="/#services"
              class="text-text-muted hover:text-accent text-sm transition-colors"
              >Engineering</a
            >
            <a
              href="/#services"
              class="text-text-muted hover:text-accent text-sm transition-colors"
              >Incubation</a
            >
            <a
              href="/#services"
              class="text-text-muted hover:text-accent text-sm transition-colors"
              >Security</a
            >
          </div>

          <div class="flex flex-col gap-2.5">
            <h4 class="font-display text-accent mb-1 text-base">Projects</h4>
            <a
              href="https://leakix.net"
              target="_blank"
              class="text-text-muted hover:text-accent text-sm transition-colors"
              >LeakIX</a
            >
            <a
              href="https://cryptography.academy"
              target="_blank"
              class="text-text-muted hover:text-accent text-sm transition-colors"
              >Cryptography Academy</a
            >
            <a
              href="https://papyrus.badaas.eu"
              target="_blank"
              class="text-text-muted hover:text-accent text-sm transition-colors"
              >Papyrus</a
            >
          </div>

          <div class="flex flex-col gap-2.5">
            <h4 class="font-display text-accent mb-1 text-base">Resources</h4>
            <a
              href="/blog"
              class="text-text-muted hover:text-accent text-sm transition-colors"
              >Blog</a
            >
            <a
              href="/#research"
              class="text-text-muted hover:text-accent text-sm transition-colors"
              >Research</a
            >
            <a
              href="/#projects"
              class="text-text-muted hover:text-accent text-sm transition-colors"
              >Open Source</a
            >
            <a
              href="/#portfolio"
              class="text-text-muted hover:text-accent text-sm transition-colors"
              >Track Record</a
            >
          </div>

          <div class="flex flex-col gap-2.5">
            <h4 class="font-display text-accent mb-1 text-base">Contact</h4>
            <a
              href="mailto:contact@badaas.be"
              class="text-text-muted hover:text-accent text-sm transition-colors"
              >contact@badaas.be</a
            >
            <p class="text-text-muted text-sm">Belgium</p>
          </div>
        </div>
      </div>

      <div
        class="max-w-container mx-auto mt-10 flex items-center gap-4 border-t-2 border-dashed pt-5"
        style="border-color: var(--color-border)"
      >
        <div class="accent-bar-secondary"></div>
        <p class="text-text-muted text-xs">
          &copy; {new Date().getFullYear()}
          <Logo />. All rights reserved.
          <span class="font-display text-accent-secondary ml-2 opacity-50">
            Q.E.D.
          </span>
        </p>
      </div>
    </footer>
  </body>
</html>
