---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Collect all tags with counts for the sidebar
const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}
const sortedTags = [...tagCounts.entries()].sort((a, b) =>
  a[0].localeCompare(b[0]),
);
---

<BaseLayout
  title="Blog | BaDaaS"
  description="Where mathematics meets the real world. Cryptography, formal verification, and applied mathematics in practice."
>
  <section class="prose max-w-content mx-auto px-5 pt-32 pb-16">
    <h1 class="text-4xl md:text-[2.5rem]">Blog</h1>
    <p class="text-text-muted mb-10">
      Where mathematics meets the real world. We explore how cryptography,
      formal verification, and applied mathematics solve concrete problems
      across security, infrastructure, and industry.
      <a
        href="/rss.xml"
        class="text-accent ml-1 inline-flex items-center gap-1 text-sm hover:opacity-80"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <circle cx="6.18" cy="17.82" r="2.18"></circle>
          <path
            d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"
          ></path>
        </svg>
        RSS
      </a>
    </p>

    {
      sortedTags.length > 0 && (
        <div class="mb-10 flex flex-wrap gap-2">
          {sortedTags.map(([tag, count]) => (
            <a href={`/blog/tags/${tag}`} class="tag-badge-sm">
              {tag}
              <span class="tag-count-sm">{count}</span>
            </a>
          ))}
        </div>
      )
    }

    {
      posts.length === 0 ? (
        <p>No posts yet. Check back soon!</p>
      ) : (
        <div>
          {posts.map(post => (
            <div class="border-border border-b py-8 last:border-b-0">
              <h3 class="mb-2.5">
                <a
                  href={`/blog/${post.id}`}
                  class="text-accent hover:opacity-80"
                >
                  {post.data.title}
                </a>
              </h3>
              <p class="text-text-muted mb-2.5 text-sm">
                {post.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </p>
              <p class="text-text mb-3">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {post.data.tags.map(tag => (
                    <a href={`/blog/tags/${tag}`} class="tag-badge-sm">
                      {tag}
                    </a>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
