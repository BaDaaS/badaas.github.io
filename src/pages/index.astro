---
import BaseLayout from "../layouts/BaseLayout.astro";
import Logo from "../components/Logo.astro";
import MathWatermark from "../components/MathWatermark.astro";
import { getCollection } from "astro:content";

const recentPosts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const servicesJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "BaDaaS",
  url: "https://badaas.be",
  description: "Applied Mathematics & Cryptography Lab",
  areaServed: "Worldwide",
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Services",
    itemListElement: [
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Cryptographic Audits",
          description:
            "Review of cryptographic protocols, zero-knowledge circuits, and security-critical code.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Research",
          description:
            "Cryptography, zero-knowledge proofs, and applied mathematics research.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Development",
          description:
            "Production-grade cryptographic software, proof systems, and protocol libraries.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Consulting",
          description:
            "Cryptographic protocol design, security architecture, and technical strategy.",
        },
      },
    ],
  },
});

const services = [
  {
    num: "01",
    title: "Audits",
    desc: "We review cryptographic protocols, zero-knowledge circuits, and security-critical code to find vulnerabilities before they become exploits.",
  },
  {
    num: "02",
    title: "Research",
    desc: "We explore cryptography, zero-knowledge proofs, and applied mathematics. We publish our findings and build tools for the community.",
  },
  {
    num: "03",
    title: "Development",
    desc: "We build production-grade cryptographic software, from proof systems to protocol libraries.",
  },
  {
    num: "04",
    title: "Consulting",
    desc: "We advise on cryptographic protocols, security architecture, and technical strategy.",
  },
];
---

<BaseLayout
  title="BaDaaS - Applied Mathematics & Cryptography Lab"
  description="We use abstract mathematics to build concrete applications. Applied Mathematics & Cryptography Lab."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={servicesJsonLd} />
  </Fragment>

  <!-- Hero Section: left-aligned with circular logo -->
  <section
    class="relative flex min-h-screen flex-col justify-center overflow-hidden px-5 pt-24 pb-12 md:px-16"
  >
    <MathWatermark />
    <div class="relative z-10 max-w-4xl">
      <div class="accent-bar mb-8"></div>
      <div class="mb-8 flex items-center gap-8">
        <div
          class="logo-mask relative h-[120px] w-[120px] shrink-0 md:h-[160px] md:w-[160px]"
        >
        </div>
        <h1
          class="font-display text-accent m-0 text-5xl leading-none tracking-tight md:text-[6rem]"
        >
          <Logo />
        </h1>
      </div>
      <p class="text-text mb-3 max-w-[600px] text-xl font-medium">
        We use abstract mathematics to build concrete applications.
      </p>
      <p class="text-text-muted mb-10 text-base">
        Applied Mathematics & Cryptography Lab, Belgium.
      </p>
      <a href="https://calendly.com/be-danny-willems/30min" class="btn-primary">
        Book a call
      </a>
    </div>
  </section>

  <!-- Services Section: numbered notebook cards -->
  <section id="services" class="bg-bg-secondary px-5 py-16 md:px-16 md:py-24">
    <div class="max-w-container mx-auto">
      <div class="mb-12 flex items-end gap-6">
        <span class="section-number">01</span>
        <div>
          <div class="accent-bar mb-4"></div>
          <h2 class="font-display text-accent m-0 text-3xl md:text-4xl">
            What we do
          </h2>
        </div>
      </div>
      <div class="max-w-4xl">
        {
          services.map(s => (
            <div class="service-strip">
              <span class="font-display text-accent-secondary text-2xl">
                {s.num}
              </span>
              <h3 class="font-display text-accent m-0 hidden text-2xl md:block">
                {s.title}
              </h3>
              <div>
                <h3 class="font-display text-accent m-0 mb-2 text-2xl md:hidden">
                  {s.title}
                </h3>
                <p class="text-text-muted m-0 text-sm">{s.desc}</p>
              </div>
            </div>
          ))
        }
        <div class="border-border border-t"></div>
      </div>
    </div>
  </section>

  <!-- Track Record Section -->
  <section
    id="portfolio"
    class="max-w-container mx-auto px-5 py-16 md:px-16 md:py-24"
  >
    <div class="mb-12 flex items-end gap-6">
      <span class="section-number">02</span>
      <div>
        <div class="accent-bar-secondary mb-4"></div>
        <h2 class="font-display text-accent m-0 text-3xl md:text-4xl">
          Track Record
        </h2>
      </div>
    </div>

    <!-- Trust Metrics -->
    <div
      class="border-border mb-16 grid grid-cols-2 gap-px border md:grid-cols-4"
      style="background: var(--color-border)"
    >
      <div class="bg-bg px-6 py-8 text-center">
        <p class="font-display text-accent m-0 text-4xl md:text-5xl">7+</p>
        <p class="text-text-muted m-0 mt-2 text-sm">Years in cryptography</p>
      </div>
      <div class="bg-bg px-6 py-8 text-center">
        <p class="font-display text-accent m-0 text-4xl md:text-5xl">3</p>
        <p class="text-text-muted m-0 mt-2 text-sm">
          L1 protocols contributed to
        </p>
      </div>
      <div class="bg-bg px-6 py-8 text-center">
        <p class="font-display text-accent m-0 text-4xl md:text-5xl">ZK</p>
        <p class="text-text-muted m-0 mt-2 text-sm">
          Proof systems and circuits
        </p>
      </div>
      <div class="bg-bg px-6 py-8 text-center">
        <p class="font-display text-accent-secondary m-0 text-4xl md:text-5xl">
          BE
        </p>
        <p class="text-text-muted m-0 mt-2 text-sm">Based in Belgium</p>
      </div>
    </div>

    <!-- Featured Engagements -->
    <h3 class="font-display text-text-muted mb-6 text-lg tracking-wide">
      Selected engagements
    </h3>
    <div class="max-w-4xl">
      <a
        href="https://minaprotocol.com"
        class="border-border group block border-t py-8 no-underline hover:opacity-100"
        target="_blank"
      >
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
          <div class="shrink-0 md:w-48">
            <h4
              class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
            >
              Mina Protocol
            </h4>
            <p class="text-accent-secondary m-0 mt-1 text-xs">
              Zero-Knowledge Proofs
            </p>
          </div>
          <p class="text-text-muted m-0 text-sm leading-relaxed">
            Core contributor to the Mina Protocol node. Designed and implemented
            zero-knowledge proof systems, cryptographic primitives, and
            protocol-level logic in OCaml and Rust.
          </p>
        </div>
      </a>
      <a
        href="https://tezos.com"
        class="border-border group block border-t py-8 no-underline hover:opacity-100"
        target="_blank"
      >
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
          <div class="shrink-0 md:w-48">
            <h4
              class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
            >
              Tezos
            </h4>
            <p class="text-accent-secondary m-0 mt-1 text-xs">
              Protocol Development
            </p>
          </div>
          <p class="text-text-muted m-0 text-sm leading-relaxed">
            Protocol-level development and cryptographic research for the Tezos
            ecosystem, working with Nomadic Labs on core infrastructure and
            proof-of-stake consensus mechanisms.
          </p>
        </div>
      </a>
      <a
        href="https://leakix.net"
        class="border-border group block border-t py-8 no-underline hover:opacity-100"
        target="_blank"
      >
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
          <div class="shrink-0 md:w-48">
            <h4
              class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
            >
              LeakIX
            </h4>
            <p class="text-accent-secondary m-0 mt-1 text-xs">
              Security Research
            </p>
          </div>
          <p class="text-text-muted m-0 text-sm leading-relaxed">
            Cryptographic engineering for a security intelligence platform.
            Built privacy-preserving systems and secure data processing
            pipelines.
          </p>
        </div>
      </a>
      <div class="border-border border-t"></div>
    </div>

    <!-- Additional Clients -->
    <div class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-4">
      <p class="text-text-muted m-0 text-sm">Also worked with</p>
      <a
        href="https://www.b2c2.com"
        class="font-display text-text-muted hover:text-accent text-xl no-underline transition-colors hover:opacity-100"
        target="_blank">B2C2</a
      >
      <a
        href="https://www.nomadic-labs.com"
        class="font-display text-text-muted hover:text-accent text-xl no-underline transition-colors hover:opacity-100"
        target="_blank">Nomadic Labs</a
      >
    </div>
  </section>

  <!-- Open Source Section -->
  <section id="projects" class="bg-bg-secondary px-5 py-16 md:px-16 md:py-24">
    <div class="max-w-container mx-auto">
      <div class="mb-12 flex items-end gap-6">
        <span class="section-number">03</span>
        <div>
          <div class="accent-bar mb-4"></div>
          <h2 class="font-display text-accent m-0 text-3xl md:text-4xl">
            Open Source
          </h2>
        </div>
      </div>

      <div class="max-w-4xl">
        <!-- Mina Protocol (OCaml) -->
        <a
          href="https://github.com/MinaProtocol/mina"
          class="border-border group block border-t py-8 no-underline hover:opacity-100"
          target="_blank"
        >
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
            <div class="shrink-0 md:w-48">
              <h4
                class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
              >
                Mina Protocol
              </h4>
              <div class="mt-2 flex flex-wrap gap-2">
                <span
                  class="border-accent/30 text-accent border px-2 py-0.5 text-xs"
                  >OCaml</span
                >
                <span
                  class="border-accent/30 text-accent border px-2 py-0.5 text-xs"
                  >ZK Proofs</span
                >
              </div>
            </div>
            <p class="text-text-muted m-0 text-sm leading-relaxed">
              Core contributor to the Mina Protocol node. Implemented
              cryptographic primitives, proof system integrations, and consensus
              logic for the world's lightest blockchain.
            </p>
          </div>
        </a>

        <!-- Mina Rust -->
        <a
          href="https://github.com/o1-labs/mina-rust"
          class="border-border group block border-t py-8 no-underline hover:opacity-100"
          target="_blank"
        >
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
            <div class="shrink-0 md:w-48">
              <h4
                class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
              >
                Mina Rust
              </h4>
              <div class="mt-2 flex flex-wrap gap-2">
                <span
                  class="border-accent/30 text-accent border px-2 py-0.5 text-xs"
                  >Rust</span
                >
                <span
                  class="border-accent/30 text-accent border px-2 py-0.5 text-xs"
                  >P2P</span
                >
              </div>
            </div>
            <p class="text-text-muted m-0 text-sm leading-relaxed">
              Rust implementation of the Mina Protocol node. Rewrites
              performance-critical components in Rust for memory safety and
              speed, including networking and state management.
            </p>
          </div>
        </a>

        <!-- Mina Explorer -->
        <a
          href="https://github.com/dannywillems/mina-explorer"
          class="border-border group block border-t py-8 no-underline hover:opacity-100"
          target="_blank"
        >
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
            <div class="shrink-0 md:w-48">
              <h4
                class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
              >
                Mina Explorer
              </h4>
              <div class="mt-2 flex flex-wrap gap-2">
                <span
                  class="border-accent/30 text-accent border px-2 py-0.5 text-xs"
                  >Explorer</span
                >
                <span
                  class="border-accent/30 text-accent border px-2 py-0.5 text-xs"
                  >Web</span
                >
              </div>
            </div>
            <p class="text-text-muted m-0 text-sm leading-relaxed">
              Blockchain explorer for Mina Protocol networks. Browse blocks,
              transactions, and account activity across Mina's zero-knowledge
              proof chain.
            </p>
          </div>
        </a>

        <!-- Zcash Web Wallet -->
        <a
          href="https://github.com/LeakIX/zcash-web-wallet"
          class="border-border group block border-t py-8 no-underline hover:opacity-100"
          target="_blank"
        >
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
            <div class="shrink-0 md:w-48">
              <h4
                class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
              >
                Zcash Web Wallet
              </h4>
              <div class="mt-2 flex flex-wrap gap-2">
                <span
                  class="border-accent/30 text-accent border px-2 py-0.5 text-xs"
                  >Privacy</span
                >
                <span
                  class="border-accent/30 text-accent border px-2 py-0.5 text-xs"
                  >Zcash</span
                >
              </div>
            </div>
            <p class="text-text-muted m-0 text-sm leading-relaxed">
              Browser-based Zcash wallet with shielded transaction support.
              Handles zk-SNARK proof generation client-side for private
              transfers without trusting a server.
            </p>
          </div>
        </a>

        <!-- Zcash Infra -->
        <a
          href="https://github.com/LeakIX/zcash-infra"
          class="border-border group block border-t py-8 no-underline hover:opacity-100"
          target="_blank"
        >
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
            <div class="shrink-0 md:w-48">
              <h4
                class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
              >
                Zcash Infra
              </h4>
              <div class="mt-2 flex flex-wrap gap-2">
                <span
                  class="border-accent/30 text-accent border px-2 py-0.5 text-xs"
                  >DevOps</span
                >
                <span
                  class="border-accent/30 text-accent border px-2 py-0.5 text-xs"
                  >Zcash</span
                >
              </div>
            </div>
            <p class="text-text-muted m-0 text-sm leading-relaxed">
              Infrastructure tooling for deploying and managing Zcash full nodes
              and related services. Automated provisioning, monitoring, and
              maintenance.
            </p>
          </div>
        </a>

        <div class="border-border border-t"></div>
      </div>

      <!-- Cryptography Academy (separate, educational) -->
      <div class="mt-12 max-w-4xl">
        <a
          href="https://cryptography.academy"
          class="group flex items-center gap-6 no-underline hover:opacity-100"
          target="_blank"
        >
          <div class="accent-bar-secondary"></div>
          <div>
            <h4
              class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors"
            >
              Cryptography Academy
            </h4>
            <p class="text-text-muted m-0 mt-1 text-sm">
              Free educational platform for cryptography and mathematics. Open
              to everyone.
            </p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Recent Blog Posts -->
  {
    recentPosts.length > 0 && (
      <section
        id="blog"
        class="max-w-container mx-auto px-5 py-16 md:px-16 md:py-24"
      >
        <div class="mb-12 flex items-end gap-6">
          <span class="section-number">04</span>
          <div>
            <div class="accent-bar-secondary mb-4" />
            <h2 class="font-display text-accent m-0 text-3xl md:text-4xl">
              Latest Posts
            </h2>
          </div>
        </div>
        <div class="max-w-content">
          {recentPosts.map(post => (
            <div class="border-accent/20 mb-6 border-l-3 py-6 pl-6">
              <h3 class="font-display mb-2.5 text-2xl">
                <a
                  href={`/blog/${post.slug}`}
                  class="text-accent hover:opacity-80"
                >
                  {post.data.title}
                </a>
              </h3>
              <p class="text-text-muted mb-2.5 text-sm">
                {post.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </p>
              <p class="text-text">{post.data.description}</p>
            </div>
          ))}
        </div>
        <p class="mt-10">
          <a href="/blog" class="btn-secondary">
            View all posts
          </a>
        </p>
      </section>
    )
  }
</BaseLayout>
