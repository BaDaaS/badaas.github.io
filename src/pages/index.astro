---
import BaseLayout from "../layouts/BaseLayout.astro";
import Logo from "../components/Logo.astro";
import MathWatermark from "../components/MathWatermark.astro";
import { getCollection } from "astro:content";

const recentPosts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const servicesJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "BaDaaS",
  url: "https://badaas.be",
  description:
    "From abstract mathematics to concrete applications. Formal verification, applied cryptography, and Internet security.",
  areaServed: "Worldwide",
  foundingDate: "2020",
  address: {
    "@type": "PostalAddress",
    addressCountry: "BE",
  },
  founder: {
    "@type": "Person",
    name: "Danny Willems",
    url: "https://dannywillems.github.io",
    sameAs: [
      "https://twitter.com/be_badaas",
      "https://github.com/dannywillems",
      "https://github.com/BaDaaS",
      "https://linkedin.com/company/bebadaas",
    ],
  },
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Services",
    itemListElement: [
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Research",
          description:
            "Mathematics, formal verification, and cryptography. We publish papers, contribute to open knowledge, and advance the foundations that everything else builds on.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Engineering",
          description:
            "We build and maintain software, from low-level cryptographic libraries to full infrastructure. Distributed systems, networking layers, proof systems, open source tooling, and production systems.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Projects",
          description:
            "We explore and develop projects that make the Internet safer and knowledge more accessible. LeakIX, Cryptography Academy, and Papyrus all started here.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Security",
          description:
            "Attack surface management, cryptographic audits, and vulnerability research. The applied side of our mission to protect the Internet.",
        },
      },
    ],
  },
});

const services = [
  {
    num: "01",
    title: "Research",
    desc: "Mathematics, formal verification, and cryptography. We publish papers, contribute to open knowledge, and advance the foundations that everything else builds on.",
  },
  {
    num: "02",
    title: "Engineering",
    desc: "We build and maintain software, from low-level cryptographic libraries to full infrastructure. Distributed systems, networking layers, proof systems, open source tooling, and production systems.",
  },
  {
    num: "03",
    title: "Projects",
    desc: 'We explore and develop projects that make the Internet safer and knowledge more accessible. <a href="https://leakix.net" target="_blank" rel="noopener noreferrer">LeakIX</a>, <a href="https://cryptography.academy" target="_blank" rel="noopener noreferrer">Cryptography Academy</a>, and <a href="https://papyrus.badaas.eu" target="_blank" rel="noopener noreferrer">Papyrus</a> all started here.',
  },
  {
    num: "04",
    title: "Security",
    desc: "Attack surface management, cryptographic audits, and vulnerability research. The applied side of our mission to protect the Internet.",
  },
];
---

<BaseLayout
  title="BaDaaS - Making the Internet Better"
  description="From abstract mathematics to concrete applications. Formal verification, applied cryptography, and Internet security."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={servicesJsonLd} />
  </Fragment>

  <!-- Hero Section: left-aligned with mission block on the right -->
  <section
    class="relative flex min-h-screen flex-col justify-center overflow-hidden px-5 pt-24 pb-12 md:px-16"
  >
    <MathWatermark />

    <!-- Mission block (right side, desktop only) -->
    <div
      class="absolute top-0 right-0 hidden h-full w-[38%] items-center justify-center lg:flex"
      style="background: var(--color-accent-secondary); opacity: 0.07"
    >
    </div>
    <div
      class="absolute top-0 right-0 z-10 hidden h-full w-[38%] items-center px-12 lg:flex"
    >
      <div class="max-w-md">
        <div class="accent-bar-secondary mb-6"></div>
        <p class="font-display text-accent text-3xl leading-tight xl:text-4xl">
          Making the Internet better.
        </p>
        <p class="text-text-muted mt-4 text-base leading-relaxed">
          We use abstract mathematics to build concrete applications.
        </p>
        <p class="text-text-muted mt-6 text-sm leading-relaxed opacity-70">
          The original Internet was about open knowledge, free for everyone, and
          individual freedom. We build the mathematics that keeps it that way:
          cryptography for privacy, formal verification for trust, and open
          source so knowledge stays accessible to all.
        </p>
      </div>
    </div>

    <div class="relative z-10 max-w-4xl lg:max-w-[55%]">
      <div class="accent-bar mb-8"></div>
      <div class="mb-8 flex items-center gap-8">
        <div
          class="logo-mask relative h-[120px] w-[120px] shrink-0 md:h-[160px] md:w-[160px]"
        >
        </div>
        <h1
          class="font-display text-accent m-0 text-5xl leading-none tracking-tight md:text-[6rem]"
        >
          <Logo />
        </h1>
      </div>
      <!-- Mobile: show mission inline -->
      <p class="text-text mb-3 max-w-[600px] text-xl font-medium lg:hidden">
        We use abstract mathematics to build concrete applications.
      </p>
      <p class="text-text mb-3 max-w-[600px] text-xl font-medium lg:hidden">
        Making the Internet better.
      </p>
      <p class="text-text-muted mb-4 max-w-[540px] text-base leading-relaxed">
        We research and build projects in cryptography and Internet security.
      </p>
      <p
        class="text-text-muted mb-10 max-w-[540px] text-sm leading-relaxed opacity-70 lg:hidden"
      >
        The original Internet was about open knowledge, free for everyone, and
        individual freedom. We build the mathematics that keeps it that way:
        cryptography for privacy, formal verification for trust, and open source
        so knowledge stays accessible to all.
      </p>
      <a href="https://calendly.com/be-danny-willems/30min" class="btn-primary">
        Book a call
      </a>
    </div>
  </section>

  <!-- Services Section: numbered notebook cards -->
  <section id="services" class="bg-bg-secondary px-5 py-16 md:px-16 md:py-24">
    <div class="max-w-container mx-auto">
      <div class="mb-12 flex items-end gap-6">
        <span class="section-number">01</span>
        <div>
          <div class="accent-bar mb-4"></div>
          <h2 class="font-display text-accent m-0 text-3xl md:text-4xl">
            What we do
          </h2>
        </div>
      </div>
      <div class="max-w-4xl">
        {
          services.map(s => (
            <div class="service-strip">
              <span class="font-display text-accent-secondary text-2xl">
                {s.num}
              </span>
              <h3 class="font-display text-accent m-0 hidden text-2xl md:block">
                {s.title}
              </h3>
              <div>
                <h3 class="font-display text-accent m-0 mb-2 text-2xl md:hidden">
                  {s.title}
                </h3>
                <p class="text-text-muted m-0 text-sm" set:html={s.desc} />
              </div>
            </div>
          ))
        }
        <div class="border-border border-t"></div>
      </div>
    </div>
  </section>

  <!-- Track Record Section -->
  <section
    id="portfolio"
    class="max-w-container mx-auto px-5 py-16 md:px-16 md:py-24"
  >
    <div class="mb-12 flex items-end gap-6">
      <span class="section-number">02</span>
      <div>
        <div class="accent-bar-secondary mb-4"></div>
        <h2 class="font-display text-accent m-0 text-3xl md:text-4xl">
          Track Record
        </h2>
      </div>
    </div>

    <!-- Trust Metrics -->
    <div
      class="border-border mb-16 grid grid-cols-2 gap-px border md:grid-cols-4"
      style="background: var(--color-border)"
    >
      <div class="bg-bg px-6 py-8 text-center">
        <p class="font-display text-accent m-0 text-4xl md:text-5xl">2020</p>
        <p class="text-text-muted m-0 mt-2 text-sm">Founded</p>
      </div>
      <div class="bg-bg px-6 py-8 text-center">
        <p class="font-display text-accent m-0 text-4xl md:text-5xl">2</p>
        <p class="text-text-muted m-0 mt-2 text-sm">Protocols contributed to</p>
      </div>
      <div class="bg-bg px-6 py-8 text-center">
        <p class="font-display text-accent m-0 text-4xl md:text-5xl">5+</p>
        <p class="text-text-muted m-0 mt-2 text-sm">Publications and talks</p>
      </div>
      <div class="bg-bg px-6 py-8 text-center">
        <p class="font-display text-accent-secondary m-0 text-4xl md:text-5xl">
          BE
        </p>
        <p class="text-text-muted m-0 mt-2 text-sm">Based in Belgium</p>
      </div>
    </div>

    <!-- Featured Engagements -->
    <h3 class="font-display text-text-muted mb-6 text-lg tracking-wide">
      Selected engagements
    </h3>
    <div class="max-w-4xl">
      <a
        href="https://minaprotocol.com"
        class="border-border group block border-t py-8 no-underline hover:opacity-100"
        target="_blank"
        rel="noopener noreferrer"
      >
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
          <div class="shrink-0 md:w-48">
            <h4
              class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
            >
              Mina Protocol
            </h4>
            <p class="text-accent-secondary m-0 mt-1 text-xs">
              Zero-Knowledge Proofs
            </p>
          </div>
          <p class="text-text-muted m-0 text-sm leading-relaxed">
            Core contributor to the Mina Protocol with o1Labs. Contributed to
            Kimchi (proof system), Pickles (recursive composition), and o1vm
            (zkVM for MIPS). Drafted Arrabbiata (folding-based proving system).
            Cryptographic primitives and protocol-level logic in OCaml and Rust.
          </p>
        </div>
      </a>
      <a
        href="https://tezos.com"
        class="border-border group block border-t py-8 no-underline hover:opacity-100"
        target="_blank"
        rel="noopener noreferrer"
      >
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
          <div class="shrink-0 md:w-48">
            <h4
              class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
            >
              Tezos
            </h4>
            <p class="text-accent-secondary m-0 mt-1 text-xs">
              Protocol Development
            </p>
          </div>
          <p class="text-text-muted m-0 text-sm leading-relaxed">
            Protocol-level development and cryptographic research for the Tezos
            ecosystem with Nomadic Labs. Core infrastructure, ZK rollups, and
            low-level cryptographic engineering in OCaml.
          </p>
        </div>
      </a>
      <a
        href="https://leakix.net"
        class="border-border group block border-t py-8 no-underline hover:opacity-100"
        target="_blank"
        rel="noopener noreferrer"
      >
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
          <div class="shrink-0 md:w-48">
            <h4
              class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
            >
              LeakIX
            </h4>
            <p class="text-accent-secondary m-0 mt-1 text-xs">
              Co-founded by BaDaaS
            </p>
          </div>
          <p class="text-text-muted m-0 text-sm leading-relaxed">
            Internet-wide attack surface management platform, co-founded and
            actively developed by BaDaaS. Indexes misconfigurations and
            vulnerabilities across the Internet with responsible disclosure.
            100+ clients.
          </p>
        </div>
      </a>
      <a
        href="https://www.b2c2.com"
        class="border-border group block border-t py-8 no-underline hover:opacity-100"
        target="_blank"
        rel="noopener noreferrer"
      >
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
          <div class="shrink-0 md:w-48">
            <h4
              class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
            >
              B2C2
            </h4>
            <p class="text-accent-secondary m-0 mt-1 text-xs">
              Trading Infrastructure
            </p>
          </div>
          <p class="text-text-muted m-0 text-sm leading-relaxed">
            First engineer at B2C2, now a leading institutional digital asset
            market maker (London, Standard Chartered partner). Built exchange
            interfaces, real-time blockchain transaction detection, accounting
            systems, and risk management pipelines for the trading desk.
            Maintained multi-chain node infrastructure. 2017 - 2020.
          </p>
        </div>
      </a>
      <div class="border-border border-t"></div>
    </div>

    <!-- Additional Clients -->
    <div class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-4">
      <p class="text-text-muted m-0 text-sm">Also worked with</p>
      <a
        href="https://www.nomadic-labs.com"
        class="font-display text-text-muted hover:text-accent text-xl no-underline transition-colors hover:opacity-100"
        target="_blank"
        rel="noopener noreferrer">Nomadic Labs</a
      >
      <a
        href="https://www.inria.fr"
        class="font-display text-text-muted hover:text-accent text-xl no-underline transition-colors hover:opacity-100"
        target="_blank"
        rel="noopener noreferrer">INRIA</a
      >
      <a
        href="https://web.umons.ac.be"
        class="font-display text-text-muted hover:text-accent text-xl no-underline transition-colors hover:opacity-100"
        target="_blank"
        rel="noopener noreferrer">UMONS</a
      >
    </div>
  </section>

  <!-- Research Section -->
  <section id="research" class="bg-bg-secondary px-5 py-16 md:px-16 md:py-24">
    <div class="max-w-container mx-auto">
      <div class="mb-12 flex items-end gap-6">
        <span class="section-number">03</span>
        <div>
          <div class="accent-bar mb-4"></div>
          <h2 class="font-display text-accent m-0 text-3xl md:text-4xl">
            Research
          </h2>
        </div>
      </div>

      <!-- Publications -->
      <div class="max-w-4xl">
        <div class="border-border flex items-center gap-4 border-t py-4">
          <span
            class="border-accent text-accent border px-3 py-1 text-xs font-medium tracking-widest uppercase"
            >Publications</span
          >
          <span class="text-text-muted text-xs"
            >Cryptography, type theory, and applied mathematics</span
          >
        </div>

        <a
          href="https://eprint.iacr.org/2022/840"
          class="border-border group block border-t py-8 no-underline hover:opacity-100"
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
            <div class="shrink-0 md:w-48">
              <h4
                class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
              >
                Anemoi
              </h4>
              <p class="text-text-muted m-0 mt-1 text-xs">2022</p>
              <div class="mt-2 flex flex-wrap gap-2">
                <span
                  class="border-accent/30 text-accent border px-2 py-0.5 text-xs"
                  >Hash Functions</span
                >
                <span
                  class="border-accent/30 text-accent border px-2 py-0.5 text-xs"
                  >ZK Proofs</span
                >
              </div>
            </div>
            <div>
              <p class="text-text m-0 text-sm leading-relaxed font-medium">
                New Design Techniques for Efficient Arithmetization-Oriented
                Hash Functions: Anemoi Permutations and Jive Compression Mode
              </p>
              <p class="text-text-muted m-0 mt-2 text-xs">
                C. Bouvier, P. Briaud, P. Chaidos, L. Perrin, R. Salen, V.
                Velichkov, D. Willems
              </p>
            </div>
          </div>
        </a>

        <a
          href="https://eprint.iacr.org/2022/462"
          class="border-border group block border-t py-8 no-underline hover:opacity-100"
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
            <div class="shrink-0 md:w-48">
              <h4
                class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
              >
                PlonK
              </h4>
              <p class="text-text-muted m-0 mt-1 text-xs">2022</p>
              <div class="mt-2 flex flex-wrap gap-2">
                <span
                  class="border-accent/30 text-accent border px-2 py-0.5 text-xs"
                  >zk-SNARKs</span
                >
                <span
                  class="border-accent/30 text-accent border px-2 py-0.5 text-xs"
                  >Optimization</span
                >
              </div>
            </div>
            <div>
              <p class="text-text m-0 text-sm leading-relaxed font-medium">
                New optimization techniques for PlonK's arithmetization
              </p>
              <p class="text-text-muted m-0 mt-2 text-xs">
                M. Ambrona, A.-L. Schmitt, R. R. Toledo, D. Willems
              </p>
            </div>
          </div>
        </a>
        <a
          href="https://github.com/dannywillems/master-thesis/"
          class="border-border group block border-t py-8 no-underline hover:opacity-100"
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
            <div class="shrink-0 md:w-48">
              <h4
                class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
              >
                RML
              </h4>
              <p class="text-text-muted m-0 mt-1 text-xs">
                Master's Thesis, 2017
              </p>
              <div class="mt-2 flex flex-wrap gap-2">
                <span
                  class="border-accent/30 text-accent border px-2 py-0.5 text-xs"
                  >Type Systems</span
                >
                <span
                  class="border-accent/30 text-accent border px-2 py-0.5 text-xs"
                  >OCaml</span
                >
              </div>
            </div>
            <div>
              <p class="text-text m-0 text-sm leading-relaxed font-medium">
                To a typed language for modular programming
              </p>
              <p class="text-text-muted m-0 mt-2 text-xs">
                D. Willems. Directed by F. Pottier (INRIA Paris)
              </p>
            </div>
          </div>
        </a>

        <div class="border-border border-t"></div>
      </div>

      <!-- Talks -->
      <div class="mt-12 max-w-4xl">
        <div class="border-border flex items-center gap-4 border-t py-4">
          <span
            class="border-accent-secondary text-accent-secondary border px-3 py-1 text-xs font-medium tracking-widest uppercase"
            >Talks</span
          >
          <span class="text-text-muted text-xs">Conference presentations</span>
        </div>

        <a
          href="https://www.youtube.com/watch?v=HDH2KXRAxAc"
          class="border-border group block border-t py-8 no-underline hover:opacity-100"
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
            <div class="shrink-0 md:w-48">
              <h4
                class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
              >
                ZK Summit 11
              </h4>
              <p class="text-text-muted m-0 mt-1 text-xs">2024</p>
            </div>
            <p class="text-text-muted m-0 text-sm leading-relaxed">
              o1VM: Building a Real-World zkVM for MIPS. Bitwise operation
              encoding, folding schemes, and RAM lookups.
            </p>
          </div>
        </a>

        <a
          href="https://www.youtube.com/watch?v=hR1lwvc3LBg"
          class="border-border group block border-t py-8 no-underline hover:opacity-100"
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
            <div class="shrink-0 md:w-48">
              <h4
                class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
              >
                SevenX Research Day
              </h4>
              <p class="text-text-muted m-0 mt-1 text-xs">2024</p>
            </div>
            <p class="text-text-muted m-0 text-sm leading-relaxed">
              A zkVM for the MIPS architecture and OP fault proofs.
            </p>
          </div>
        </a>

        <a
          href="https://www.youtube.com/watch?v=3EdbLiClFPI"
          class="border-border group block border-t py-8 no-underline hover:opacity-100"
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
            <div class="shrink-0 md:w-48">
              <h4
                class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
              >
                ZKProof 5
              </h4>
              <p class="text-text-muted m-0 mt-1 text-xs">Tel Aviv, 2022</p>
            </div>
            <p class="text-text-muted m-0 text-sm leading-relaxed">
              Anemoi & Jive: New Arithmetization-Oriented Tools for PlonK. With
              C. Bouvier.
            </p>
          </div>
        </a>
        <div class="border-border border-t"></div>
      </div>
    </div>
  </section>

  <!-- Open Source Section -->
  <section id="projects" class="px-5 py-16 md:px-16 md:py-24">
    <div class="max-w-container mx-auto">
      <div class="mb-12 flex items-end gap-6">
        <span class="section-number">04</span>
        <div>
          <div class="accent-bar mb-4"></div>
          <h2 class="font-display text-accent m-0 text-3xl md:text-4xl">
            Open Source
          </h2>
        </div>
      </div>

      <div class="max-w-4xl">
        <div class="border-border flex items-center gap-4 border-t py-4">
          <span
            class="border-accent text-accent border px-3 py-1 text-xs font-medium tracking-widest uppercase"
            >Core Contributions</span
          >
          <span class="text-text-muted text-xs"
            >Long-term protocol-level work</span
          >
        </div>
        <a
          href="https://github.com/MinaProtocol/mina"
          class="border-border group block border-t py-8 no-underline hover:opacity-100"
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-12">
            <div class="shrink-0 md:w-48">
              <h4
                class="font-display text-accent group-hover:text-accent-secondary m-0 text-2xl transition-colors md:text-3xl"
              >
                Mina Protocol
              </h4>
              <p class="text-text-muted m-0 mt-1 text-xs">2023 - 2026</p>
